    "#| label: fig-demo-plotly\n",
    "#| fig-cap: 'Demo: a Cobb-Douglas utility surface as a Plotly figure.'\n",
    "#| fig-cap-location: margin\n",
    "\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "x = np.linspace(0.1, 10, 60)\n",
    "y = np.linspace(0.1, 10, 60)\n",
    "X, Y = np.meshgrid(x, y)\n",
    "alpha = 0.4\n",
    "U = X ** alpha * Y ** (1 - alpha)\n",
    "\n",
    "fig = go.Figure(data=[go.Surface(x=X, y=Y, z=U, colorscale=\"Viridis\")])\n",
    "fig.update_layout(\n",
    "    title=\"u(x, y) = x^0.4 · y^0.6\",\n",
    "    scene=dict(xaxis_title=\"x\", yaxis_title=\"y\", zaxis_title=\"u\"),\n",
    "    width=600,\n",
    "    height=450,\n",
    "    margin=dict(l=0, r=0, b=0, t=40),\n",
    ")\n",
    "fig.show()"
   ]
