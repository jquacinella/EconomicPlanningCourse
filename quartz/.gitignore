# Quartz build artifacts
public/
.quartz-cache/

# Node
node_modules/
npm-debug.log*

# Files fetched by setup.sh from upstream Quartz on first install. We commit
# only our overrides (quartz.config.ts, quartz.layout.ts, README.md, setup.sh,
# .gitignore, content symlink); everything below is pulled in on first
# `bash setup.sh && npm ci`.
#
# Why `quartz/*` and not `quartz/`: a directory ignore can never be undone by a
# later `!` rule on a path inside it (documented .gitignore semantic). The Quartz
# Static emitter calls globby with `gitignore: true` and follows the same rule,
# so ignoring the whole `quartz/` tree silently dropped icon.png / og-image.png
# from public/static/, 404'ing the favicon on deep pages of the deployed notes
# site. Listing children with `quartz/*` keeps `!quartz/static/` effective.
quartz/*
!quartz/static/
docs/
content/.gitkeep
*.lock
package.json
package-lock.json
tsconfig.json
globals.d.ts
index.d.ts

# But DO commit our config and layout overrides — they live at the top of
# this directory and not in the ignored subpaths.
!quartz.config.ts
!quartz.layout.ts

# OS junk
.DS_Store
