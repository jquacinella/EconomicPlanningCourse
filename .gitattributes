* text=auto eol=lf

# Binary assets — never normalize line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.epub binary
*.ttf  binary
*.otf  binary
*.woff  binary
*.woff2 binary
*.mky  binary
*.rvl  binary

# Notebooks — keep as text but mark for clean diffs
*.ipynb text
